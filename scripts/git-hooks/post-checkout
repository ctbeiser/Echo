#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel 2>/dev/null || true)"
if [[ -z "$repo_root" ]]; then
  exit 0
fi

cd "$repo_root"

if [[ ! -d "$repo_root/DerivedData" && -x "$repo_root/scripts/seed-derived-data.sh" ]]; then
  "$repo_root/scripts/seed-derived-data.sh" >/dev/null 2>&1 || true
fi
